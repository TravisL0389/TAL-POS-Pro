
# LocalPOS Pro Environment Variables
# Duplicate this file to .env.local and fill in the values.

# Supabase backend
# Use the publishable key from your Supabase project settings.
# If your project still labels it as an anon key, you can use VITE_SUPABASE_ANON_KEY instead.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# VITE_SUPABASE_ANON_KEY=your_legacy_supabase_anon_key

# Optional defaults for future extensions
DEFAULT_TAX_RATE=0.08
DEFAULT_CURRENCY=$
DEFAULT_DELIVERY_FEE=4.99
